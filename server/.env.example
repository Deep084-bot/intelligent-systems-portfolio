# Gemini API key (Google Cloud API key or service account token)
GEMINI_API_KEY=your_api_key_here
# Model name (gemini-1.5 or gemini-1.5-flash). Use full resource like "models/gemini-1.5" if needed.
GEMINI_MODEL=models/gemini-1.5-flash
# Optional: API URL override if using proxy
GEMINI_API_URL=https://generativemodels.googleapis.com/v1
# Server port
PORT=4000
